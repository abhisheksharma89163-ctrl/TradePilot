# ============================================================
# BOS — Business Operating System :: Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ============================================================

# ---- Supabase (Project Settings -> API) --------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- AI / OCR (document reading) ---------------------------
# Google Gemini Vision — powers reading photos of slips/cheques.
# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
# Optional: override the model (default is gemini-2.0-flash).
GEMINI_MODEL="gemini-2.0-flash"

# OpenRouter (optional fallback AI provider)
OPENROUTER_API_KEY=""

# ---- App ---------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BOS"
