# ============================================================
# BOS — Business Operating System :: Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ============================================================

# ---- Supabase (Project Settings -> API) --------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- AI / OCR (Phase 2) ------------------------------------
# Google Gemini Vision (primary OCR + AI assistant)
GEMINI_API_KEY="your-gemini-api-key"

# OpenRouter (optional fallback AI provider)
OPENROUTER_API_KEY=""

# ---- App ---------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BOS"
