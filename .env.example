# ============================================================
# BOS — Business Operating System :: Environment Variables
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local`.
# ============================================================

# ---- Supabase (Project Settings -> API) --------------------
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# Service role key — SERVER ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ---- AI / OCR (document reading) ---------------------------
# The app tries these providers in order and auto-falls-back when one
# is busy/rate-limited. Add as many as you like — more = more reliable.

# 1) Google Gemini Vision (primary). Free: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key"
GEMINI_MODEL="gemini-2.0-flash"

# 2) Groq (fast, generous free tier). Free: https://console.groq.com/keys
GROQ_API_KEY=""
GROQ_MODEL="meta-llama/llama-4-scout-17b-16e-instruct"

# 3) OpenRouter (aggregator, free vision models). Free: https://openrouter.ai/keys
OPENROUTER_API_KEY=""
OPENROUTER_MODEL="meta-llama/llama-3.2-11b-vision-instruct:free"

# ---- App ---------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="BOS"
